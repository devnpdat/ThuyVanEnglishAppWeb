{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "flutter build web --release --no-pub",
    "watchPatterns": []
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/",
    "restartPolicyType": "always",
    "restartPolicyMaxRetries": 5
  }
}
